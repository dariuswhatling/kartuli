# Copy to .env for local development. Set these as environment variables in Coolify for production.

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string

# Set to "false" in production.
DJANGO_DEBUG=true

# Comma-separated list of hostnames Django will serve. Include your Coolify domain(s).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated full origins (scheme + host) trusted for CSRF (required for HTTPS in prod).
# Example: https://kartuli.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# Database URL. Leave unset to use local SQLite. In production set to a Postgres URL, e.g.
# postgres://USER:PASSWORD@HOST:5432/DBNAME
# DATABASE_URL=

# Optional production hardening.
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SECURE_HSTS_SECONDS=3600
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
# DJANGO_SECURE_HSTS_PRELOAD=true

# Port the app binds to inside the container (Coolify sets this automatically).
PORT=8000
