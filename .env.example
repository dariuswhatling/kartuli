# Copy to .env for local development. Set the same variables in Coolify for production.

# REQUIRED. Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string

# REQUIRED. "true" for local dev, "false" in production.
DJANGO_DEBUG=true

# --- Everything below is optional; sensible defaults are used if unset. ---

# Comma-separated hostnames Django will serve. Defaults to "*" (any host),
# which is fine behind Coolify's reverse proxy. Tighten if you want to.
# DJANGO_ALLOWED_HOSTS=kartuli.example.com

# Comma-separated full origins trusted for CSRF (scheme + host). Auto-derived
# from DJANGO_ALLOWED_HOSTS as https://<host>, so usually you don't need this.
# DJANGO_CSRF_TRUSTED_ORIGINS=https://kartuli.example.com

# Database. Defaults to local SQLite. Set to a Postgres URL in production:
#   postgres://USER:PASSWORD@HOST:5432/DBNAME
# DATABASE_URL=

# Optional production hardening.
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SECURE_HSTS_SECONDS=3600
